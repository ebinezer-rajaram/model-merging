[run]
source =
    core
    merging
    tasks
    continual_suite_lib
omit =
    */__pycache__/*
    */tests/*
    */venv/*
    */.venv/*
    */site-packages/*
    # CLI entrypoints are thin argparse/subprocess dispatch layers; behavior is
    # covered through the underlying callable modules.
    */core/evaluation/evaluate_task.py
    */merging/cli.py
    */merging/continual/cli.py
    */merging/evaluation/cli.py

    # Full training/evaluation orchestration needs real processors, models,
    # checkpoints, or long-running Trainer workflows. Small pure helpers from
    # these areas should be tested after extraction into focused modules.
    */core/evaluation/eval_utils.py
    */core/evaluation/plotting.py
    */core/models/models.py
    */core/tasks/collator.py
    */core/tasks/dataset.py
    */core/training/train_task.py
    */core/training/train_multitask.py
    */core/training/trainer.py
    */core/training/training_loop.py
    */core/training/run_manager.py
    */core/training/constrained_decoding.py
    */core/training/multitask_sampler.py
    */core/training/multitask_eval.py
    */merging/continual/evaluate.py
    */merging/continual/supermerge_optimizer.py
    */merging/evaluation/evaluate.py
    */merging/evaluation/interference.py
    */merging/evaluation/continual_sweep.py
    */merging/optimizers/adamerging.py
    */merging/optimizers/gradient.py
    */merging/optimizers/regret_smoothmax.py
    */merging/optimizers/supermerge.py
    */merging/optimizers/core/*

    # Runtime discovery and adapter save/load utilities depend on repository
    # artifact layouts and external checkpoint conventions.
    */merging/runtime/utils.py
    */merging/runtime/logging.py

    # These are filesystem/model adapter orchestration layers; the pure merge
    # math, runner behavior, registry behavior, and task-vector IO are covered.
    */merging/engine/builtin_methods.py
    */merging/methods/task_vector.py

    # MELD requires a local external bundle; the shared classification loader
    # behavior is covered through patched/local emotion dataset tests.
    */tasks/emotion/meld_loader.py
    */tasks/speaker_ver/dataset.py

[report]
fail_under = 80
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    raise NotImplementedError
    pass
